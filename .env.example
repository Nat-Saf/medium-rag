# Copy to .env (gitignored) and fill in. All model calls go through LLMod.

# --- LLMod (OpenAI-compatible API) ---
LLMOD_API_KEY=your-llmod-api-key
LLMOD_BASE_URL=https://your-llmod-host/v1

# --- Pinecone ---
PINECONE_API_KEY=your-pinecone-api-key

# --- Ingestion (optional; defaults to medium-english-50mb.csv) ---
CSV_PATH=medium-english-50mb.csv
